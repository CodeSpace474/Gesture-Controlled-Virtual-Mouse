import cv2
import mediapipe as mp
import pyautogui
import numpy as np
import os

# --- PATH SETUP ---
SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
MODEL_PATH = os.path.join(SCRIPT_DIR, 'hand_landmarker.task')

# --- AI INITIALIZATION ---
BaseOptions = mp.tasks.BaseOptions
HandLandmarker = mp.tasks.vision.HandLandmarker
HandLandmarkerOptions = mp.tasks.vision.HandLandmarkerOptions
VisionRunningMode = mp.tasks.vision.RunningMode

screen_w, screen_h = pyautogui.size()
plocX, plocY = 0, 0
smooth = 3 # Lower = Faster, Higher = Smoother
latest_result = None
frame_timestamp = 0 # Manual counter to prevent ValueError

def result_callback(result, output_image, timestamp_ms):
    global latest_result
    latest_result = result

options = HandLandmarkerOptions(
    base_options=BaseOptions(model_asset_path=MODEL_PATH),
    running_mode=VisionRunningMode.LIVE_STREAM,
    result_callback=result_callback,
    num_hands=1,
    min_hand_detection_confidence=0.6 # Slightly lower for better tracking
)

with HandLandmarker.create_from_options(options) as landmarker:
    cap = cv2.VideoCapture(0)
    # Improve camera performance
    cap.set(cv2.CAP_PROP_FRAME_WIDTH, 640)
    cap.set(cv2.CAP_PROP_FRAME_HEIGHT, 480)

    while cap.isOpened():
        success, frame = cap.read()
        if not success: break
        
        frame = cv2.flip(frame, 1)
        h, w, _ = frame.shape
        mp_image = mp.Image(image_format=mp.ImageFormat.SRGB, data=frame)
        
        # INCREMENT TIMESTAMP MANUALLY (Fixes the crash)
        frame_timestamp += 1
        landmarker.detect_async(mp_image, frame_timestamp)
        
        if latest_result and latest_result.hand_landmarks:
            for landmarks in latest_result.hand_landmarks:
                # Landmark 8: Index Tip, Landmark 4: Thumb Tip
                itip = landmarks[8]
                ttip = landmarks[4]
                
                # 1. Map Coordinates (Centered Box)
                margin = 120
                fx = np.interp(itip.x * w, (margin, w - margin), (0, screen_w))
                fy = np.interp(itip.y * h, (margin, h - margin), (0, screen_h))
                
                # 2. Smooth Movement
                clocX = plocX + (fx - plocX) / smooth
                clocY = plocY + (fy - plocY) / smooth
                
                # Move cursor without PyAutoGUI's default 0.1s delay
                pyautogui.moveTo(clocX, clocY, _pause=False)
                plocX, plocY = clocX, clocY
                
                # 3. BETTER CLICK LOGIC (3D distance check)
                # We check distance in image coordinates
                ix, iy = itip.x * w, itip.y * h
                tx, ty = ttip.x * w, ttip.y * h
                dist = np.hypot(ix - tx, iy - ty)
                
                if dist < 35: # Tight pinch threshold
                    cv2.circle(frame, (int(ix), int(iy)), 15, (0, 255, 0), cv2.FILLED)
                    pyautogui.click()
                    # Small sleep to prevent "machine gun" clicking
                    pyautogui.PAUSE = 0.1
        # Show the frame
        cv2.imshow("Gesture Mouse (Press Q to Exit)", frame)
        
        # 1. Check if 'q' is pressed OR if the window's 'X' button was clicked
        key = cv2.waitKey(1) & 0xFF
        if key == ord('q') or cv2.getWindowProperty("Gesture Mouse (Press Q to Exit)", cv2.WND_PROP_VISIBLE) < 1:
            break

    cap.release()
    cv2.destroyAllWindows()

